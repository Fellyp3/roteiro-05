using System;

namespace AulaMatematica
{
    class Program
    {
        static void Main(string[] args)
        {
            for (int i = 1; i <= 5; i++)
            {
                Console.WriteLine("Digite o " + i + "º número decimal:");
                double num = double.Parse(Console.ReadLine());

                Console.WriteLine("Original: " + num);
                Console.WriteLine("Round: " + Math.Round(num));
                Console.WriteLine("Floor: " + Math.Floor(num));
                Console.WriteLine("Ceiling: " + Math.Ceiling(num));
                Console.WriteLine("Truncate: " + Math.Truncate(num));
                Console.WriteLine("-----------------------");
            }

            Console.ReadLine();
        }
    }
}









using System;

namespace CalculoInvestimento
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.WriteLine("Digite o capital inicial:");
            double capital = double.Parse(Console.ReadLine());

            Console.WriteLine("Digite a taxa de juros mensal (ex: 0,01 para 1%):");
            double taxa = double.Parse(Console.ReadLine());

            Console.WriteLine("Digite o número de meses:");
            int meses = int.Parse(Console.ReadLine());

            Console.WriteLine("Digite sua meta de lucro:");
            double meta = double.Parse(Console.ReadLine());

            // Fórmula: M = C * (1 + i)^t
            double montante = capital * Math.Pow((1 + taxa), meses);
            double lucro = montante - capital;
            double lucroArredondado = Math.Round(lucro, 2);

            Console.WriteLine("Lucro total: R$ " + lucroArredondado);

            if (lucroArredondado > meta)
            {
                Console.WriteLine("Parabéns! O lucro supera a meta.");
            }
            else
            {
                Console.WriteLine("O lucro ainda não atingiu a meta.");
            }

            Console.ReadLine();
        }
    }
}







