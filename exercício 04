using System;

namespace AulaDatas
{
    class Program
    {
        static void Main()
        {
            Console.WriteLine("Digite seu nome:");
            string nome = Console.ReadLine();

            Console.WriteLine("Digite a data e hora do compromisso (dd/MM/yyyy HH:mm):");
            string entrada = Console.ReadLine();
            
            DateTime dataCompromisso = DateTime.Parse(entrada);
            DateTime agora = DateTime.Now;

            TimeSpan diferenca = dataCompromisso - agora;
            int diasFaltam = diferenca.Days;

            string diaSemana = dataCompromisso.ToString("dddd");

            string mensagem = string.Format("Olá, {0}!\nSeu compromisso será em {1} dias, na {2}.\nData marcada: {3:dd/MM/yyyy} às {3:HH:mm}", 
                nome, 
                diasFaltam, 
                diaSemana, 
                dataCompromisso);

            Console.WriteLine(mensagem);

            Console.ReadLine();
        }
    }
}
